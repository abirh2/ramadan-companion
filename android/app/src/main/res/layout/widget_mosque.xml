<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_mosque_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:gravity="start"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nearest Mosque"
        android:textSize="10sp"
        android:textColor="#888888"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <View
        android:layout_width="match_parent"
        android:layout_height="6dp" />

    <!-- Mosque name -->
    <TextView
        android:id="@+id/widget_mosque_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open app"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#0f3d3e"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Distance -->
    <TextView
        android:id="@+id/widget_mosque_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#10BA7A"
        android:layout_marginTop="2dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Address -->
    <TextView
        android:id="@+id/widget_mosque_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#888888"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
