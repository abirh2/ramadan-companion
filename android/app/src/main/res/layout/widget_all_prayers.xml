<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_ap_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Prayers"
        android:textSize="11sp"
        android:textColor="#888888"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <!-- Prayer columns row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Fajr -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg">

            <TextView
                android:id="@+id/widget_ap_fajr_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAJR"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/widget_ap_fajr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#0f3d3e"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Dhuhr -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg">

            <TextView
                android:id="@+id/widget_ap_dhuhr_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DHUHR"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/widget_ap_dhuhr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#0f3d3e"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Asr -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg">

            <TextView
                android:id="@+id/widget_ap_asr_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASR"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/widget_ap_asr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#0f3d3e"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Maghrib -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg">

            <TextView
                android:id="@+id/widget_ap_maghrib_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAGHR"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/widget_ap_maghrib_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#0f3d3e"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Isha -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg">

            <TextView
                android:id="@+id/widget_ap_isha_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ISHA"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/widget_ap_isha_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#0f3d3e"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
