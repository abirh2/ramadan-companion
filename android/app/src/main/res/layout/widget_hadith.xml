<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_hadith_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hadith of the Day"
            android:textSize="11sp"
            android:textColor="#10BA7A"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAHIH"
            android:textSize="9sp"
            android:textColor="#10BA7A"
            android:textStyle="bold"
            android:background="@drawable/widget_pill_badge"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />
    </LinearLayout>

    <!-- Arabic text (RTL) -->
    <TextView
        android:id="@+id/widget_hadith_arabic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1a1a1a"
        android:textAlignment="viewEnd"
        android:layoutDirection="rtl"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingExtra="3dp"
        android:layout_marginTop="6dp" />

    <!-- Translation -->
    <TextView
        android:id="@+id/widget_hadith_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open the app to load today's hadith."
        android:textSize="13sp"
        android:textColor="#1a1a1a"
        android:maxLines="4"
        android:ellipsize="end"
        android:lineSpacingExtra="2dp"
        android:layout_marginTop="6dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Source attribution -->
    <TextView
        android:id="@+id/widget_hadith_source"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#666666"
        android:textStyle="bold" />

</LinearLayout>
