<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_hijri_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:gravity="start"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Islamic Date"
        android:textSize="10sp"
        android:textColor="#888888"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <!-- Day number (large) -->
    <TextView
        android:id="@+id/widget_hijri_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#0f3d3e"
        android:layout_marginTop="2dp" />

    <!-- Month name -->
    <TextView
        android:id="@+id/widget_hijri_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open app"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#10BA7A" />

    <!-- Year -->
    <TextView
        android:id="@+id/widget_hijri_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#666666" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Weekday -->
    <TextView
        android:id="@+id/widget_hijri_weekday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#888888" />

    <!-- Gregorian date -->
    <TextView
        android:id="@+id/widget_hijri_gregorian"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#888888" />

</LinearLayout>
